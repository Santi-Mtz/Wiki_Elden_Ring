{
  "rewrites": [
    {
      "source": "/api/auth/(.*)",
      "destination": "https://TU-BACKEND-RAILWAY.up.railway.app/auth/$1"
    },
    {
      "source": "/api/events/(.*)",
      "destination": "https://TU-BACKEND-RAILWAY.up.railway.app/events/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://TU-BACKEND-RAILWAY.up.railway.app/api/$1"
    }
  ]
}
